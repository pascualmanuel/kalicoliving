# Supabase (blog posts)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: for blog cover images from Supabase Storage, add your project hostname
# (e.g. your-project.supabase.co) to next.config.js images.remotePatterns

# Cloudinary (blog images) – use full image URLs in Supabase (list_image_url / cover_url)
# NEXT_PUBLIC_ only for client-side; never expose API secret (use CLOUDINARY_API_SECRET on server)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
